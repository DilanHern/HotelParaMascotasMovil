# ========================
# CONFIGURACIÓN DE SUPABASE
# ========================
SUPABASE_URL=https://your-project.supabase.co
SUPABASE_ANON_KEY=your_anon_key_here

# ========================
# CONFIGURACIÓN DE EMAIL
# ========================
# Para Gmail:
EMAIL_HOST=smtp.gmail.com
EMAIL_PORT=587
EMAIL_SECURE=false
EMAIL_USER=your-email@gmail.com
EMAIL_PASSWORD=your-app-specific-password

# Para SendGrid (opcional):
# SENDGRID_API_KEY=your_sendgrid_api_key

# Email remitente
EMAIL_FROM=noreply@hotelmascotasxyz.com

# ========================
# CONFIGURACIÓN DEL SERVIDOR
# ========================
NODE_ENV=development
PORT=3000

# ========================
# NOTAS SOBRE CONFIGURACIÓN
# ========================
# 1. Para Gmail:
#    - Habilitar "Less secure app access" o usar "App Password"
#    - Generar una contraseña específica de aplicación en tu cuenta de Google
#
# 2. Para otros proveedores de SMTP:
#    - Gmail: smtp.gmail.com:587
#    - Outlook: smtp-mail.outlook.com:587
#    - Yahoo: smtp.mail.yahoo.com:465 (secure: true)
#
# 3. SendGrid (alternativa de SendGrid):
#    - Crear API key en SendGrid dashboard
#    - Usar emailService actualizado para SendGrid
